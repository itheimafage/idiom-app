[
  { "text": "人民对美好生活的向往，就是我们的奋斗目标。", "source": "人民日报", "theme": "民生" },
  { "text": "绿水青山就是金山银山。", "source": "人民日报", "theme": "生态" },
  { "text": "惟改革者进，惟创新者强，惟改革创新者胜。", "source": "人民日报", "theme": "改革" },
  { "text": "功成不必在我，功成必定有我。", "source": "人民日报", "theme": "担当" },
  { "text": "治国有常，利民为本。", "source": "人民日报", "theme": "民生" },
  { "text": "大道至简，实干为要。", "source": "人民日报", "theme": "实干" },
  { "text": "征程万里风正劲，重任千钧再出发。", "source": "人民日报", "theme": "奋斗" },
  { "text": "天下之事，不难于立法，而难于法之必行。", "source": "人民日报", "theme": "法治" },
  { "text": "历史只会眷顾坚定者、奋进者、搏击者，而不会等待犹豫者、懈怠者、畏难者。", "source": "人民日报", "theme": "奋斗" },
  { "text": "民之所忧，我必念之；民之所盼，我必行之。", "source": "人民日报", "theme": "民生" },
  { "text": "守正创新，行稳致远。", "source": "人民日报", "theme": "发展" },
  { "text": "文化自信是更基本、更深沉、更持久的力量。", "source": "人民日报", "theme": "文化" },
  { "text": "乡村振兴，既要塑形，也要铸魂。", "source": "人民日报", "theme": "三农" },
  { "text": "法治兴则国兴，法治强则国强。", "source": "人民日报", "theme": "法治" },
  { "text": "人不负青山，青山定不负人。", "source": "人民日报", "theme": "生态" },
  { "text": "创新是引领发展的第一动力。", "source": "人民日报", "theme": "创新" },
  { "text": "青年兴则国家兴，青年强则国家强。", "source": "人民日报", "theme": "青年" },
  { "text": "国以才立，政以才治，业以才兴。", "source": "人民日报", "theme": "人才" },
  { "text": "于安思危，于治忧乱。", "source": "人民日报", "theme": "治理" },
  { "text": "时代是出卷人，我们是答卷人，人民是阅卷人。", "source": "人民日报", "theme": "担当" },
  { "text": "改革不停顿，开放不止步。", "source": "人民日报", "theme": "改革" },
  { "text": "人民至上，生命至上。", "source": "人民日报", "theme": "民生" },
  { "text": "一花独放不是春，百花齐放春满园。", "source": "人民日报", "theme": "合作" },
  { "text": "科技是国家强盛之基，创新是民族进步之魂。", "source": "人民日报", "theme": "科技" },
  { "text": "路虽远，行则将至；事虽难，做则必成。", "source": "人民日报", "theme": "实干" },
  { "text": "教育是国之大计、党之大计。", "source": "人民日报", "theme": "教育" },
  { "text": "民生无小事，枝叶总关情。", "source": "人民日报", "theme": "民生" },
  { "text": "伟大梦想不是等得来、喊得来的，而是拼出来、干出来的。", "source": "人民日报", "theme": "奋斗" },
  { "text": "法安天下，德润人心。", "source": "人民日报", "theme": "法治" },
  { "text": "苟日新，日日新，又日新。", "source": "人民日报", "theme": "创新" },
  { "text": "志之所趋，无远弗届；穷山距海，不能限也。", "source": "人民日报", "theme": "奋斗" },
  { "text": "江山就是人民，人民就是江山。", "source": "人民日报", "theme": "民生" },
  { "text": "众人拾柴火焰高，众人植树树成林。", "source": "人民日报", "theme": "团结" },
  { "text": "把论文写在祖国的大地上。", "source": "人民日报", "theme": "实干" },
  { "text": "没有全民健康，就没有全面小康。", "source": "人民日报", "theme": "民生" },
  { "text": "抓创新就是抓发展，谋创新就是谋未来。", "source": "人民日报", "theme": "创新" },
  { "text": "开放带来进步，封闭必然落后。", "source": "人民日报", "theme": "改革" },
  { "text": "人不率则不从，身不先则不信。", "source": "人民日报", "theme": "作风" },
  { "text": "知屋漏者在宇下，知政失者在草野。", "source": "人民日报", "theme": "治理" },
  { "text": "艰难方显勇毅，磨砺始得玉成。", "source": "人民日报", "theme": "奋斗" },
  { "text": "万物各得其和以生，各得其养以成。", "source": "人民日报", "theme": "生态" },
  { "text": "用汗水浇灌收获，以实干笃定前行。", "source": "人民日报", "theme": "实干" },
  { "text": "新故相推，日生不滞。", "source": "人民日报", "theme": "发展" },
  { "text": "志合者，不以山海为远。", "source": "人民日报", "theme": "合作" },
  { "text": "大道不孤，天下一家。", "source": "人民日报", "theme": "合作" },
  { "text": "幸福都是奋斗出来的。", "source": "人民日报", "theme": "奋斗" },
  { "text": "空谈误国，实干兴邦。", "source": "人民日报", "theme": "实干" },
  { "text": "法令行则国治，法令弛则国乱。", "source": "人民日报", "theme": "法治" },
  { "text": "国之称富者，在乎丰民。", "source": "人民日报", "theme": "民生" },
  { "text": "秉纲而目自张，执本而末自从。", "source": "人民日报", "theme": "治理" },
  { "text": "大江流日夜，慷慨歌未央。", "source": "人民日报", "theme": "奋斗" },
  { "text": "凡益之道，与时偕行。", "source": "人民日报", "theme": "发展" },
  { "text": "为者常成，行者常至。", "source": "人民日报", "theme": "实干" },
  { "text": "人才者，求之则愈出，置之则愈匮。", "source": "人民日报", "theme": "人才" },
  { "text": "善除害者察其本，善理疾者绝其源。", "source": "人民日报", "theme": "治理" },
  { "text": "胜非其难也，持之者其难也。", "source": "人民日报", "theme": "治理" },
  { "text": "万物并育而不相害，道并行而不相悖。", "source": "人民日报", "theme": "文化" },
  { "text": "欲筑室者，先治其基。", "source": "人民日报", "theme": "治理" },
  { "text": "治国犹如栽树，本根不摇则枝叶茂荣。", "source": "人民日报", "theme": "治理" },
  { "text": "穷则变，变则通，通则久。", "source": "人民日报", "theme": "改革" },
  { "text": "计利当计天下利。", "source": "人民日报", "theme": "担当" },
  { "text": "心有所信，方能行远。", "source": "人民日报", "theme": "信念" },
  { "text": "青春由磨砺而出彩，人生因奋斗而升华。", "source": "人民日报", "theme": "青年" },
  { "text": "征途漫漫，惟有奋斗。", "source": "人民日报", "theme": "奋斗" },
  { "text": "风清则气正，气正则心齐，心齐则事成。", "source": "人民日报", "theme": "作风" },
  { "text": "利民之事，丝发必兴；厉民之事，毫末必去。", "source": "人民日报", "theme": "民生" },
  { "text": "聚天下英才而用之。", "source": "人民日报", "theme": "人才" },
  { "text": "积力之所举，则无不胜也；众智之所为，则无不成也。", "source": "人民日报", "theme": "团结" },
  { "text": "仓廪实而知礼节，衣食足而知荣辱。", "source": "人民日报", "theme": "民生" },
  { "text": "善学者尽其理，善行者究其难。", "source": "人民日报", "theme": "学习" },
  { "text": "道虽迩，不行不至；事虽小，不为不成。", "source": "人民日报", "theme": "实干" },
  { "text": "看似寻常最奇崛，成如容易却艰辛。", "source": "人民日报", "theme": "奋斗" },
  { "text": "明者因时而变，知者随事而制。", "source": "人民日报", "theme": "改革" },
  { "text": "石可破也，而不可夺坚；丹可磨也，而不可夺赤。", "source": "人民日报", "theme": "信念" },
  { "text": "落其实者思其树，饮其流者怀其源。", "source": "人民日报", "theme": "文化" },
  { "text": "治天下也，必先公，公则天下平矣。", "source": "人民日报", "theme": "治理" },
  { "text": "天地之大，黎元为先。", "source": "人民日报", "theme": "民生" },
  { "text": "法立于上，教弘于下。", "source": "人民日报", "theme": "法治" },
  { "text": "不谋万世者，不足谋一时；不谋全局者，不足谋一域。", "source": "人民日报", "theme": "治理" },
  { "text": "周虽旧邦，其命维新。", "source": "人民日报", "theme": "创新" },
  { "text": "大厦之成，非一木之材也；大海之阔，非一流之归也。", "source": "人民日报", "theme": "团结" },
  { "text": "芳林新叶催陈叶，流水前波让后波。", "source": "人民日报", "theme": "发展" },
  { "text": "安而不忘危，存而不忘亡，治而不忘乱。", "source": "人民日报", "theme": "治理" },
  { "text": "政之所兴在顺民心，政之所废在逆民心。", "source": "人民日报", "theme": "民生" },
  { "text": "能用众力，则无敌于天下矣；能用众智，则无畏于圣人矣。", "source": "人民日报", "theme": "团结" },
  { "text": "日月不肯迟，四时相催迫。", "source": "人民日报", "theme": "奋斗" },
  { "text": "居安思危，思则有备，有备无患。", "source": "人民日报", "theme": "治理" },
  { "text": "行之力则知愈进，知之深则行愈达。", "source": "人民日报", "theme": "学习" },
  { "text": "举一纲而万目张，解一卷而众篇明。", "source": "人民日报", "theme": "治理" },
  { "text": "事辍者无功，耕怠者无获。", "source": "人民日报", "theme": "实干" },
  { "text": "天下之患，最不可为者，名为治平无事，而其实有不测之忧。", "source": "人民日报", "theme": "治理" },
  { "text": "欲知大道，必先为史。", "source": "人民日报", "theme": "文化" },
  { "text": "功崇惟志，业广惟勤。", "source": "人民日报", "theme": "奋斗" },
  { "text": "人生万事须自为，跬步江山即寥廓。", "source": "人民日报", "theme": "奋斗" },
  { "text": "本固才能枝荣，根深才能叶茂。", "source": "人民日报", "theme": "治理" },
  { "text": "犯其至难而图其至远。", "source": "人民日报", "theme": "奋斗" },
  { "text": "求木之长者，必固其根本；欲流之远者，必浚其泉源。", "source": "人民日报", "theme": "治理" },
  { "text": "长风破浪会有时，直挂云帆济沧海。", "source": "人民日报", "theme": "奋斗" },
  { "text": "博观而约取，厚积而薄发。", "source": "人民日报", "theme": "学习" },
  { "text": "古之立大事者，不惟有超世之才，亦必有坚忍不拔之志。", "source": "人民日报", "theme": "信念" }
]
